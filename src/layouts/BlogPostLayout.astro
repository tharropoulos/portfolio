---
import type { CollectionEntry } from "astro:content";

import BackButton from "@/components/back-button";
import Prose from "@/components/prose.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatBlogDate } from "@/lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  minutesRead?: string;
}

const { post, minutesRead } = Astro.props;

const publishedLabel = formatBlogDate(post.data.publishedAt);
const updatedLabel = post.data.updatedAt
  ? formatBlogDate(post.data.updatedAt)
  : null;
---

<BaseLayout
  currentPath={`/blog/${post.id}`}
  title={`${post.data.title} | Fanis Tharropoulos`}
  description={post.data.description}
>
  <main class="container mx-auto flex min-h-screen w-full max-w-screen-sm flex-col bg-background pb-16">
    <div class="animate-fadein-slide opacity-0 transition-all [--fadein-delay:10ms]">
      <article>
        <BackButton href="/blog" label="Back to writing" className="mb-4 mt-20 lg:mt-28" />

        <header class="border-b border-border/70 pb-8 mt-6">
          <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
            <time datetime={post.data.publishedAt.toISOString()}>{publishedLabel}</time>
            {minutesRead && (
              <span>{minutesRead}</span>
            )}
            {updatedLabel && (
              <span>Updated {updatedLabel}</span>
            )}
          </div>
          <h1 class="mt-2 text-4xl font-bold tracking-tight md:text-5xl">
            {post.data.title}
          </h1>
          <p class="mt-3 max-w-2xl text-base leading-7 text-muted-foreground md:text-lg">
            {post.data.description}
          </p>
          {post.data.tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <li class="rounded-full bg-muted px-3 py-1 text-xs font-medium uppercase tracking-[0.12em] text-foreground/80">
                  {tag}
                </li>
              ))}
            </ul>
          )}
        </header>
        <Prose>
          <slot />
        </Prose>
      </article>
    </div>
  </main>
</BaseLayout>
