---
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";
import Navbar from "@/components/main-nav";
import ScrollProgressBar from "@/components/scrollbar";
import "@/index.css";

interface Props {
  title?: string;
  description?: string;
  currentPath: string;
}

const {
  title = "Fanis Tharropoulos | Software Engineer",
  description = "Software engineer based in Athens, Greece. Projects, experience, and things I'm excited about.",
  currentPath,
} = Astro.props;

const links = [
  { id: "about", href: "/", label: "About" },
  { id: "work", href: "/experience", label: "Work" },
  { id: "writing", href: "/blog", label: "Writing" },
];
const showScrollProgressBar =
  currentPath === "/" || (currentPath.startsWith("/blog/") && currentPath !== "/blog");
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <Analytics />
    <title>{title}</title>
  </head>
  <body>
    <div class="flex min-h-screen w-full flex-col items-center bg-background">
      <div transition:persist class="fixed inset-x-0 top-0 z-50">
        <Navbar client:load currentPath={currentPath} links={links} />
      </div>
      {showScrollProgressBar && (
        <div class="pointer-events-none fixed inset-x-0 top-0 z-50 h-16">
          <ScrollProgressBar
            client:load
            color="oklch(0.777 0.152 181.912)"
            strokeSize={2}
          />
        </div>
      )}
      <slot />
    </div>
  </body>
</html>
