---
import Analytics from "@vercel/analytics/astro";
import Navbar from "@/components/main-nav";
import ScrollProgressBar from "@/components/scrollbar";
import "@/index.css";

interface Props {
  title?: string;
  description?: string;
  currentPath: string;
}

const {
  title = "Fanis Tharropoulos | Software Engineer",
  description = "Software engineer based in Athens, Greece. Projects, experience, and things I'm excited about.",
  currentPath,
} = Astro.props;

const links = [
  { id: "about", href: "/#about", label: "About" },
  { id: "work", href: "/#work", label: "Work" },
  { id: "school", href: "/#school", label: "School" },
  { id: "interests", href: "/#interests", label: "Interests" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <Analytics />
    <title>{title}</title>
  </head>
  <body>
    <div class="flex min-h-screen w-full flex-col items-center bg-background">
      <div class="fixed inset-x-0 top-0 z-50">
        <Navbar client:idle currentPath={currentPath} links={links} />
        <ScrollProgressBar
          client:idle
          color="oklch(0.777 0.152 181.912)"
          strokeSize={2}
        />
      </div>
      <slot />
    </div>
  </body>
</html>
