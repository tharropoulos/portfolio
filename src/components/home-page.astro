---
import {
  GitHubLogoIcon,
  LinkedInLogoIcon,
  TwitterLogoIcon,
} from "@radix-ui/react-icons";

import { AnimatedUnderline } from "@/components/animated-underline";
import WorkExperienceList from "@/components/experience-list";
import Footer from "@/components/footer";
import { Heading } from "@/components/heading";
import { InterestsList } from "@/components/interests-list";
import SocialLinks from "@/components/socials";
import { profile } from "@/data/profile";
import { experiences, school } from "@/data/experiences";

const socialIcons = {
  github: GitHubLogoIcon,
  linkedin: LinkedInLogoIcon,
  x: TwitterLogoIcon,
} as const;

const socials = profile.socials.map((social) => ({
  href: social.href,
  icon: socialIcons[social.id],
}));
---

<>
  <main class="container mx-auto flex min-h-screen w-full max-w-screen-sm flex-col gap-6 bg-background">
    <div class="animate-fadein-slide opacity-0 transition-all [--fadein-delay:0ms]">
      <section id="home" class="mt-24 lg:mt-32">
        <div class="mb-10">
          <h1 class="mb-3 scroll-m-20 text-3xl font-extrabold tracking-tight md:text-4xl lg:text-5xl">
            {profile.name}
          </h1>
          <h3 class="scroll-m-20 text-lg font-semibold tracking-tight md:text-2xl">
            {profile.role}
          </h3>
        </div>
        <p class="leading-6 text-muted-foreground md:text-xl">
          {profile.intro}
        </p>
        <SocialLinks className="my-5 md:my-10" socials={socials} />
      </section>
      <div class="flex flex-col gap-20">
        <section id="about" class="flex flex-col">
          <Heading title="About" />
          <div class="flex w-full flex-col">
            <div class="overflow-hidden sm:w-full lg:h-[30rem]">
              <img
                src={profile.photo.src}
                alt={profile.photo.alt}
                class="h-full animate-pan-zoom bg-cover object-cover"
              />
            </div>
            <p class="text-sm font-medium md:text-base">{profile.photo.caption}</p>
            <p class="text-xs text-muted-foreground md:text-sm">{profile.photo.date}</p>
          </div>
          <p class="text-sm leading-6 dark:text-zinc-200 md:text-base md:leading-7 [&:not(:first-child)]:mt-4 md:[&:not(:first-child)]:mt-6">
            {profile.about[0].beforeHighlight}
            <span class="text-sm font-semibold underline decoration-teal-400 decoration-dashed md:text-base">
              {profile.about[0].highlight}
            </span>
            {profile.about[0].afterHighlight}
            <a
              href={profile.about[0].emphasis.href}
              class="font-extrabold text-teal-600 hover:underline dark:text-teal-300"
            >
              {profile.about[0].emphasis.label}
            </a>
            {profile.about[0].afterEmphasis}
          </p>
          <p class="text-sm leading-6 dark:text-zinc-200 md:text-base md:leading-7 [&:not(:first-child)]:mt-4 md:[&:not(:first-child)]:mt-6">
            {profile.about[1].beforeHighlight}
            <span class="text-sm font-semibold underline decoration-teal-400 decoration-dashed md:text-base">
              {profile.about[1].highlight}
            </span>
            {profile.about[1].afterHighlight}
            <span class="text-sm font-semibold underline decoration-teal-400 decoration-dashed md:text-base">
              {profile.about[1].emphasis.label}
            </span>{" "}
            {profile.about[1].afterEmphasis}
          </p>
          <p class="text-sm leading-6 dark:text-zinc-200 md:text-base md:leading-7 [&:not(:first-child)]:mt-4 md:[&:not(:first-child)]:mt-6">
            {profile.about[2].beforeHighlight}
            <span class="text-sm font-semibold underline decoration-teal-400 decoration-dashed md:text-base">
              {profile.about[2].highlight}
            </span>
            {profile.about[2].afterHighlight}
          </p>
          <p class="text-sm leading-6 dark:text-zinc-200 md:text-base md:leading-7 [&:not(:first-child)]:mt-4 md:[&:not(:first-child)]:mt-6">
            I'm currently working on{" "}
            <a
              href={profile.currentProject.href}
              class="font-extrabold text-sky-600 transition-all duration-200 hover:text-sky-900 dark:text-sky-300"
            >
              <AnimatedUnderline
                client:load
                animationDelay={0.1}
                className="stroke-sky-600 transition-all duration-200 hover:stroke-sky-900 dark:stroke-sky-300"
              >
                {profile.currentProject.name}
              </AnimatedUnderline>
            </a>{" "}
            {profile.currentProject.description}{" "}
            <a
              href={profile.currentProject.repositoryHref}
              class="font-extrabold text-sky-600 hover:underline dark:text-sky-300"
            >
              Drop us a star
            </a>{" "}
          </p>
        </section>
        <section id="work" class="flex flex-col">
          <Heading
            title="Work"
            link={{
              href: "/experience",
              label: "My full work experience",
            }}
          />
          <WorkExperienceList experiences={[...experiences.slice(0, 1)]} />
        </section>
        <section id="school" class="flex flex-col">
          <Heading title="School" />
          <WorkExperienceList experiences={school} />
        </section>
        <section id="interests" class="flex flex-col">
          <Heading title="Stuff I'm into" />
          <InterestsList />
        </section>
      </div>
    </div>
  </main>
  <Footer />
</>
