---
import type { CollectionEntry } from "astro:content";

import { Arrow } from "@/components/arrow";
import { formatBlogDate } from "@/lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  minutesRead?: string;
}

const { post, minutesRead } = Astro.props;
---

<article class="grid gap-4 sm:grid-cols-[7rem_1.25rem_minmax(0,1fr)] sm:gap-5">
  <div class="flex items-center gap-3 pt-1 text-sm font-medium text-muted-foreground sm:block sm:gap-0 sm:pt-6">
    <span class="mt-1 h-10 w-1 shrink-0 rounded-full bg-teal-500 sm:hidden"></span>
    <div>
      <time datetime={post.data.publishedAt.toISOString()}>
        {formatBlogDate(post.data.publishedAt)}
      </time>
      {minutesRead && (
        <p class="mt-1 text-xs text-muted-foreground/80">{minutesRead}</p>
      )}
    </div>
  </div>

  <div class="relative hidden sm:block">
    <div class="absolute bottom-0 left-1/2 top-0 w-px -translate-x-1/2 bg-border/70"></div>
  </div>

  <a
    href={`/blog/${post.id}/`}
    class="group block rounded-2xl py-2 transition-colors duration-200 hover:bg-muted/70 sm:p-6"
  >
    <h2 class="text-2xl font-semibold tracking-tight transition-colors duration-200 group-hover:text-teal-600">
      {post.data.title}
    </h2>
    <p class="mt-3 text-sm leading-7 text-muted-foreground md:text-base">
      {post.data.description}
    </p>
    {post.data.tags.length > 0 && (
      <ul class="mt-5 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <li class="rounded-full bg-background px-2.5 py-1 text-xs font-medium text-foreground/80">
            {tag}
          </li>
        ))}
      </ul>
    )}
    <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-teal-600 transition-colors duration-200 group-hover:text-teal-700">
      Read post
      <Arrow orientation="right" className="self-center stroke-current" />
    </span>
  </a>
</article>
